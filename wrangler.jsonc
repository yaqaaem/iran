{
  "name": "iran",
  "main": "src/worker.js",
  "compatibility_date": "2026-03-21",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "iran-support-db",
      "database_id": "PUT_YOUR_D1_DATABASE_ID_HERE"
    }
  ]
}